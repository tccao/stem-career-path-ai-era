{
  "name": "cfg-v3-functions",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CFG V3 backend — Firebase Cloud Functions (2nd gen). Callables + triggers that enforce the lifecycle, passwordless access, gating, and read-light aggregates.",
  "engines": { "node": "20" },
  "main": "index.js",
  "scripts": {
    "serve": "firebase emulators:start --only functions,firestore,auth,storage",
    "deploy": "firebase deploy --only functions",
    "test": "node --test \"test/**/*.test.mjs\""
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.1.0",
    "nanoid": "^5.0.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.4.0"
  }
}
