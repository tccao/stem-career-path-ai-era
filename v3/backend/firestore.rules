rules_version = '2';
// Client-facing trust boundary (Spark-Backend.md §3). Authz comes from custom-token CLAIMS.
// Role tiers: owner > admin > student. The Admin SDK (hosted admin-gated Cloud Functions +
// local admin-cli) bypasses these rules for privileged writes (account-minting, role claims).
// A global kill-switch lives at system/lockdown — when enabled, every non-owner client write
// is denied (notLocked()), matching the Cloud Functions' lockdown guard.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.role == 'admin'; }
    function isOwner() { return isSignedIn() && request.auth.token.role == 'owner'; }
    function isStaff() { return isAdmin() || isOwner(); }
    function isActiveStudent(uid) {
      return isSignedIn()
        && request.auth.uid == uid
        && request.auth.token.role == 'student'
        && request.auth.token.accessEnds > request.time.toMillis();
    }
    // Global kill-switch: true unless an owner has flipped system/lockdown.enabled.
    function notLocked() {
      return !exists(/databases/$(database)/documents/system/lockdown)
        || get(/databases/$(database)/documents/system/lockdown).data.enabled != true;
    }
    // A non-owner write is allowed only while NOT locked down; the owner is always allowed.
    function writableNow() { return isOwner() || notLocked(); }

    // PUBLIC APPLY: an applicant (anonymous auth) may CREATE one SUBMITTED application.
    // The age/consent gate is enforced HERE (under-13 denied; 13–17 needs guardian consent).
    match /applications/{id} {
      allow create: if isSignedIn() && notLocked()
        && request.resource.data.status == 'SUBMITTED'
        && request.resource.data.ageBracket in ['13-17', '18plus']
        && (request.resource.data.ageBracket != '13-17' || request.resource.data.guardianConsent == true)
        && request.resource.data.accessChoice in ['beneficiary', 'supporter']
        && request.resource.data.keys().hasOnly(
             ['status', 'accessChoice', 'email', 'name', 'ageBracket', 'guardianConsent', 'createdAt']);
      allow read: if isStaff();
      // Staff may schedule an interview or reject — NON-minting transitions only. Moving an
      // application to GRANTED/ACTIVE still requires the Admin SDK (createUser + claims), which
      // bypasses Rules; the browser can never set those statuses here.
      allow update: if isStaff() && writableNow()
        && request.resource.data.status in ['SUBMITTED', 'INTERVIEW_SCHEDULED', 'REJECTED']
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'interviewAt', 'interviewNote', 'rejectedReason']);
      allow delete: if false;
    }

    // Provisioned member record — written only by the Admin SDK.
    match /members/{uid} {
      allow read: if isStaff() || (isSignedIn() && request.auth.uid == uid);
      allow write: if false;

      // Student self-attests completion of their OWN stage while ACTIVE + in-window + not locked.
      match /progress/{stageKey} {
        allow read: if isStaff() || isActiveStudent(uid);
        allow create, update: if isActiveStudent(uid) && notLocked()
          && request.resource.data.status == 'complete'
          && request.resource.data.keys().hasOnly(['status', 'deliverableUrl', 'completedAt']);
        allow delete: if false;
      }

      // Admin/owner stage-gate overrides (lock/unlock). Read by the student app.
      match /stageLocks/{stageKey} {
        allow read: if isStaff() || isActiveStudent(uid);
        allow write: if isStaff() && writableNow()
          && request.resource.data.keys().hasOnly(['state'])
          && request.resource.data.state in ['locked', 'unlocked'];
        allow delete: if isStaff() && writableNow();
      }
    }

    // Staff-only reads; all writes via the Admin SDK only.
    match /donations/{id} { allow read: if isStaff(); allow write: if false; }
    match /campaigns/{id} { allow read: if isStaff(); allow write: if false; }
    match /counters/{id}  { allow read: if isStaff(); allow write: if false; }

    // Append-only, tamper-evident: staff read, never client-writable.
    match /auditLog/{id}  { allow read: if isStaff(); allow write: if false; }

    // System control (lockdown kill-switch). Staff may READ it (to show the banner / let
    // Rules check it); only the OWNER may write it — admins can never lift or set lockdown.
    match /system/{id} {
      allow read: if isStaff();
      allow write: if isOwner()
        && request.resource.data.keys().hasOnly(['enabled', 'reason', 'by', 'at'])
        && request.resource.data.enabled is bool;
    }

    // Public site settings (Zeffy donate + Cal.com booking links). Public READ; WRITE by staff,
    // shape-validated, and blocked during lockdown for non-owners.
    match /settings/{id} {
      allow read: if true;
      allow write: if isStaff() && writableNow()
        && request.resource.data.keys().hasOnly(['zeffyUrl', 'calComUrl', 'updatedAt', 'updatedBy'])
        && request.resource.data.zeffyUrl is string && request.resource.data.zeffyUrl.matches('https://.*')
        && request.resource.data.calComUrl is string && request.resource.data.calComUrl.matches('https://.*');
    }

    match /{document=**}  { allow read, write: if false; }
  }
}
