rules_version = '2';
// Server-side enforcement (V3-Plan §5). Authz comes from custom-token CLAIMS, so no
// lookup reads are needed. All writes are denied to clients — only Cloud Functions
// (admin SDK, which bypasses rules) mutate data. This keeps the audit log append-only
// and prevents client-minted state.
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() { return request.auth != null && request.auth.token.role == 'admin'; }
    function isActiveStudent(uid) {
      return request.auth != null
        && request.auth.uid == uid
        && request.auth.token.role == 'student'
        && request.auth.token.accessEnds > request.time.toMillis();
    }

    // Student reads only their own denormalized dashboard (1 read renders the view).
    match /memberDashboard/{uid} {
      allow read: if isActiveStudent(uid);
      allow write: if false;
    }

    // Admin-only reads; writes via Functions only.
    match /applications/{id}      { allow read: if isAdmin();  allow write: if false; }
    match /members/{uid}          { allow read: if isAdmin() || (request.auth != null && request.auth.uid == uid); allow write: if false; }
    match /donations/{id}         { allow read: if isAdmin();  allow write: if false; }
    match /counters/{id}          { allow read: if isAdmin();  allow write: if false; }

    // Append-only, tamper-evident: never readable on hot paths, never client-writable.
    match /auditLog/{id}          { allow read: if isAdmin();  allow write: if false; }

    // Single-use access codes are server-only end to end.
    match /accessCodes/{hash}     { allow read, write: if false; }

    match /{document=**}          { allow read, write: if false; }
  }
}
