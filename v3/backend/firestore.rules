rules_version = '2';

// V3 browser boundary. Every mutation is performed by an App-Check-protected callable
// using the Admin SDK. Browser clients are read-only, and sensitive reads require a
// current (not revoked), MFA-confirmed staff token while the system is not locked down.
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function role() { return signedIn() ? request.auth.token.role : null; }
    function isOwner() { return role() == 'owner'; }
    function hasStaffRole() { return role() == 'admin' || role() == 'owner'; }
    function hasStaffMfa() { return request.auth.token.mfaEnrolled == true; }

    function tokenIsCurrent() {
      return signedIn()
        && (!exists(/databases/$(database)/documents/revocations/$(request.auth.uid))
          || (request.auth.token.sessionVersion
                == get(/databases/$(database)/documents/revocations/$(request.auth.uid)).data.sessionVersion
              && request.auth.token.auth_time
                >= get(/databases/$(database)/documents/revocations/$(request.auth.uid)).data.revokeTime - 1));
    }

    function notLocked() {
      return !exists(/databases/$(database)/documents/system/lockdown)
        || get(/databases/$(database)/documents/system/lockdown).data.enabled != true;
    }

    function staffCanRead() {
      return tokenIsCurrent() && hasStaffRole() && hasStaffMfa() && (isOwner() || notLocked());
    }

    match /applications/{id} {
      allow read: if staffCanRead();
      allow write: if false;
    }

    match /members/{uid} {
      allow read: if staffCanRead();
      allow write: if false;

      match /progress/{stageKey} {
        allow read: if staffCanRead();
        allow write: if false;
      }

      match /stageLocks/{stageKey} {
        allow read: if staffCanRead();
        allow write: if false;
      }
    }

    match /donations/{id} { allow read: if staffCanRead(); allow write: if false; }
    match /campaigns/{id} { allow read: if staffCanRead(); allow write: if false; }
    match /auditLog/{id} { allow read: if staffCanRead(); allow write: if false; }

    match /system/{id} { allow read: if staffCanRead(); allow write: if false; }

    // These links are intentionally public. Hostname allowlisting and writes live in
    // the owner-only updateSettings callable.
    match /settings/public { allow read: if true; allow write: if false; }

    match /revocations/{uid} { allow read, write: if false; }
    match /rateLimits/{id} { allow read, write: if false; }
    match /applicationIntake/{id} { allow read, write: if false; }

    match /{document=**} { allow read, write: if false; }
  }
}
