# Copy to .env for local dev, and set the same keys as Amplify environment variables.
# Values come from Firebase Console → Project settings → your Web app → SDK config.
# These are PUBLIC (not secrets) — Firestore Security Rules are the real protection.
VITE_FB_API_KEY=your-web-api-key
VITE_FB_AUTH_DOMAIN=code4good-stem-career-path.firebaseapp.com
VITE_FB_PROJECT_ID=code4good-stem-career-path
VITE_FB_STORAGE_BUCKET=code4good-stem-career-path.firebasestorage.app
VITE_FB_APP_ID=your-web-app-id
VITE_FB_FUNCTIONS_REGION=us-central1

# Production: public reCAPTCHA Enterprise site key registered with Firebase App Check.
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=your-recaptcha-enterprise-site-key

# Local emulator only. Never set true in Amplify/production.
VITE_USE_EMULATORS=false
