{
  "name": "cfg-v3-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CFG V3 frontend — public site + student SPA + admin SPA. Built with Vite, deployed to AWS Amplify Hosting. Talks to the Firebase backend via the modular Web SDK.",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:production": "node scripts/check-production-env.mjs && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:security": "node --test scripts/security-static.test.mjs",
    "verify:live": "node scripts/verify-live-security.mjs"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "vite": "^8.1.0"
  }
}
