# Copy to .env and adjust. The app is endpoint-driven: the SAME code runs against
# MiniStack, the DynamoDB Local jar, or real AWS by changing AWS_ENDPOINT_URL only.

# Local cloud endpoint.
#   MiniStack (docker compose up):     http://localhost:4566
#   DynamoDB Local jar (no Docker):    http://localhost:8000
#   Real AWS:                          leave AWS_ENDPOINT_URL unset
AWS_ENDPOINT_URL=http://localhost:4566

AWS_REGION=us-west-2

# Dummy credentials for local emulators (MiniStack/DynamoDB Local accept anything).
# For real AWS, use a real credential provider instead of these.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# HTTP server
PORT=3000

# Demo auth shim secret (stand-in for Cognito-issued JWTs — demo only; see ADR-001).
DEMO_AUTH_SECRET=dev-only-change-me

# API version prefix (URL path versioning). Routes mount under /api/${API_VERSION}.
API_VERSION=v1
