{
  // yzane Markdown PDF: render AWS `logos:aws-*` icons in HTML/PDF exports.
  //
  // The mermaid build the extension loads by default never calls
  // `registerIconPacks`, so `logos:aws-*` icons export as blue "?" placeholders
  // even though the VS Code markdown preview shows them.
  //
  // This value is a path-INDEPENDENT data: URI shim (no local file, no Linux
  // path) so the exported HTML opens anywhere -- a Windows browser, a Linux
  // browser, or a copy sent to someone else. The shim document.writes two tags:
  //   1. mermaid 11 from the jsDelivr CDN
  //   2. registerIconPacks([{ name: "logos", loader: fetch(logos icons.json) }])
  // It needs internet at view time (same as the extension's old CDN default).
  // Decoded shim + an offline alternative live in assets/diagrams/README-mermaid-logos.md.
  "markdown-pdf.mermaidServer": "data:text/javascript;base64,"
}
